#cloud-config
package_update: true
write_files:
  - path: /tmp/configure-downstream-agent.sh
    content: |
      #!/usr/bin/env bash

      set -e -u -x

      apt install -y qemu-guest-agent
      systemctl start qemu-guest-agent

      apt-get update
      #apt-get upgrade -y
      apt-get install -y \
        curl \
        vim \
        less

      echo 'DONE'
    permissions: '0755'
apt:
  preserve_sources_list: false
  primary:
    - arches: [default]
      uri: ${ubuntu_mirror}
  security:
    - arches: [default]
      uri: http://security.ubuntu.com/ubuntu
runcmd:
 - [sh, "/tmp/configure-downstream-agent.sh"]
